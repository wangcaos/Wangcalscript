local Tracer_Cache = {}
local Box2D_Cache = {}

local function GetDrawingObjects(Player)
    if not Tracer_Cache[Player] then
        Tracer_Cache[Player] = Drawing.new("Line")
        Tracer_Cache[Player].Thickness = 1
        Tracer_Cache[Player].Color = Color3.fromRGB(255, 255, 255)
        Tracer_Cache[Player].Visible = false
    end
    
    if not Box2D_Cache[Player] then
        local Box = {
            TL = Drawing.new("Line"), TR = Drawing.new("Line"),
            BL = Drawing.new("Line"), BR = Drawing.new("Line")
        }
        for _, line in pairs(Box) do
            line.Thickness = 1.2
            line.Color = Color3.fromRGB(255, 255, 255)
            line.Visible = false
        end
        Box2D_Cache[Player] = Box
    end
    
    return Tracer_Cache[Player], Box2D_Cache[Player]
end

local function ClearVisualsForPlayer(Player)
    if Tracer_Cache[Player] then
        pcall(function() Tracer_Cache[Player].Visible = false Tracer_Cache[Player]:Remove() end)
        Tracer_Cache[Player] = nil
    end
    if Box2D_Cache[Player] then
        pcall(function()
            for _, line in pairs(Box2D_Cache[Player]) do
                line.Visible = false
                line:Remove()
            end
        end)
        Box2D_Cache[Player] = nil
    end
    if Player.Character then
        local OldBox = Player.Character:FindFirstChild("WangBox", true)
        if OldBox then OldBox:Destroy() end
        local OldTag = Player.Character:FindFirstChild("WangTag", true)
        if OldTag then OldTag:Destroy() end
    end
end

