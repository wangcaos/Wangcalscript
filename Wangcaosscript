    Bar.Size = UDim2.new(1, -20, 0, 4) Bar.Position = UDim2.new(0, 10, 0, 26) Bar.BackgroundColor3 = Color3.fromRGB(30, 40, 50) Bar.Text = ""
    local Fill = Instance.new("Frame", Bar)
    Fill.Size = UDim2.new((Config[Key]-Min)/(Max-Min), 0, 1, 0) Fill.BackgroundColor3 = Color3.fromRGB(0, 180, 255) Fill.BorderSizePixel = 0
    
