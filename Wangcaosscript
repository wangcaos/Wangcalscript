local EngineConnection = nil
EngineConnection = RunService.RenderStepped:Connect(function()
    local Center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    if Config.FovCircle then
        FOV_Drawing.Position = Center FOV_Drawing.Radius = Config.FovRadius FOV_Drawing.Visible = true
    else
        FOV_Drawing.Visible = false
    end

    if Config.FullBright then
        Lighting.Ambient = Color3.fromRGB(255, 255, 255) Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    else
        Lighting.Ambient = Config.StoredAmbient Lighting.OutdoorAmbient = Config.StoredOutdoorAmbient
    end

    if Config.NoFlash then
        local pGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if pGui then
            local flash = pGui:FindFirstChild("Flash", true) or pGui:FindFirstChild("Blind", true)
            if flash and (flash:IsA("Frame") or flash:IsA("ColorCorrectionEffect")) then flash.Size = UDim2.new(0,0,0,0) pcall(function() flash.Enabled = false flash.BackgroundTransparency = 1 end) end
        end
    end

    if Config.ThirdPerson then
        LocalPlayer.CameraMode = Enum.CameraMode.Classic
        Camera.CFrame = Camera.CFrame * CFrame.new(0, 0, Config.ThirdPersonDist)
    end

    if Config.BunnyHop and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        local Char = LocalPlayer.Character
        if IsAlive(Char) and Char.Humanoid.FloorMaterial ~= Enum.Material.Air then Char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
    end

    local MyChar = LocalPlayer.Character
    if IsAlive(MyChar) then
        local MyHum = MyChar:FindFirstChildOfClass("Humanoid")
        if MyHum then
            if Config.SpeedToggle then MyHum.WalkSpeed = Config.WalkSpeed end
            if Config.JumpToggle then MyHum.UseJumpPower = true MyHum.JumpPower = Config.JumpPower end
        end
    end

    local Target = GetClosestTarget()
    if Target and Config.Aimbot then
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Target.Position), Config.Smoothness)
    end

    for _, Player in pairs(Players:GetPlayers()) do
        if Player == LocalPlayer then continue end
        
        local Line, Box2D = GetDrawingObjects(Player)
        local Char = Player.Character
        
        if Config.EspMaster and IsAlive(Char) and MyChar and MyChar:FindFirstChild("HumanoidRootPart") then
            local Root = Char.HumanoidRootPart
            local Head = Char.Head
            local Hum = Char.Humanoid
            local PColor = GetPColor(Player)
            local Dist = math.floor((Root.Position - MyChar.HumanoidRootPart.Position).Magnitude)
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
            
            local Box = Root:FindFirstChild("WangBox")
            if Config.EspBox then
                if not Box then
                    Box = Instance.new("BoxHandleAdornment") Box.Name = "WangBox" Box.Parent = Root Box.Adornee = Root Box.AlwaysOnTop = true Box.ZIndex = 10 Box.Size = Vector3.new(4, 5.8, 4)
                end
                Box.Visible = true Box.Color3 = PColor Box.Transparency = Config.EspTransparency / 100
            elseif Box then Box.Visible = false end

            local Tag = Head:FindFirstChild("WangTag")
            if (Config.EspName or Config.EspHealthBar or Config.EspWeapon) then
                if not Tag then
                    Tag = Instance.new("BillboardGui") Tag.Name = "WangTag" Tag.Parent = Head Tag.Adornee = Head Tag.Size = UDim2.new(0, 200, 0, 60) Tag.StudsOffset = Vector3.new(0, 3.5, 0) Tag.AlwaysOnTop = true
                    local L = Instance.new("TextLabel", Tag) L.Size = UDim2.new(1, 0, 1, 0) L.BackgroundTransparency = 1 L.Font = Enum.Font.SourceSans L.TextSize = 14 L.Name = "Txt"
                end
                Tag.Enabled = true
                Tag.Txt.TextColor3 = PColor
                local StrName = Config.EspName and string.format("%s [%dm]", Player.Name, Dist) or ""
                local StrHealth = Config.EspHealthBar and string.format("Health: %d", math.floor(Hum.Health)) or ""
                local StrWeapon = Config.EspWeapon and string.format("(%s)", GetTool(Char)) or ""
                Tag.Txt.Text = string.format("%s\n%s %s", StrName, StrHealth, StrWeapon)
            elseif Tag then Tag.Enabled = false end

            if Config.EspBox2D and OnScreen then
                local SizeX = Camera.ViewportSize.Y / ScreenPos.Z * 2.5
                local SizeY = Camera.ViewportSize.Y / ScreenPos.Z * 4.0
                local BX = ScreenPos.X - SizeX / 2
                local BY = ScreenPos.Y - SizeY / 2
                local Length = SizeX * 0.2
                Box2D.TL.From = Vector2.new(BX, BY) Box2D.TL.To = Vector2.new(BX + Length, BY)
                Box2D.TR.From = Vector2.new(BX + SizeX, BY) Box2D.TR.To = Vector2.new(BX + SizeX - Length, BY)
                Box2D.BL.From = Vector2.new(BX, BY + SizeY) Box2D.BL.To = Vector2.new(BX + Length, BY + SizeY)
                Box2D.BR.From = Vector2.new(BX + SizeX, BY + SizeY) Box2D.BR.To = Vector2.new(BX + SizeX - Length, BY + SizeY)
                for _, line in pairs(Box2D) do line.Color = PColor line.Visible = true end
            else
                for _, line in pairs(Box2D) do line.Visible = false end
            end

            if Config.EspTracer then
                local Leg, LegOnScreen = Camera:WorldToViewportPoint(Root.Position)
                if LegOnScreen then
                    Line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    Line.To = Vector2.new(Leg.X, Leg.Y)
                    Line.Color = PColor
                    Line.Visible = true
                else Line.Visible = false end
            else Line.Visible = false end
        else
            Line.Visible = false
            for _, line in pairs(Box2D) do line.Visible = false end
            if Char then
                local b = Char:FindFirstChild("WangBox") if b then b.Visible = false end
                local t = Char:FindFirstChild("WangTag") if t then t.Enabled = false end
            end
        end
    end
end)

