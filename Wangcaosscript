                    Tag = Instance.new("BillboardGui") Tag.Name = "WangTag" Tag.Parent = Head Tag.Adornee = Head Tag.Size = UDim2.new(0, 220, 0, 65) Tag.StudsOffset = Vector3.new(0, 3.8, 0) Tag.AlwaysOnTop = true
                    local L = Instance.new("TextLabel", Tag) L.Size = UDim2.new(1, 0, 1, 0) L.BackgroundTransparency = 1 L.Font = Enum.Font.Code L.TextSize = 13 L.Name = "Txt"
                end
                Tag.Enabled = true
                Tag.Txt.TextColor3 = PColor
                
                local StrName = Config.EspName and string.format("%s (%dm)", Player.Name, Dist) or ""
                local StrHealth = Config.EspHealthBar and string.format("HP: %d/%d", math.floor(Hum.Health), math.floor(Hum.MaxHealth)) or ""
                local StrWeapon = Config.EspWeapon and string.format("[%s]", GetTool(Char)) or ""
                
                Tag.Txt.Text = string.format("%s\n%s %s", StrName, StrHealth, StrWeapon)
            elseif Tag then Tag.Enabled = false end

            -- Corner Bounding 2D Box Engine (CSGO Style)
            if Config.EspBox2D and OnScreen then
                local SizeX = Camera.ViewportSize.Y / ScreenPos.Z * 2.8
                local SizeY = Camera.ViewportSize.Y / ScreenPos.Z * 4.2
                local BX = ScreenPos.X - SizeX / 2
                local BY = ScreenPos.Y - SizeY / 2
                
                local Length = SizeX * 0.22
                
                Box2D.TL.From = Vector2.new(BX, BY) Box2D.TL.To = Vector2.new(BX + Length, BY)
                Box2D.TR.From = Vector2.new(BX + SizeX, BY) Box2D.TR.To = Vector2.new(BX + SizeX - Length, BY)
                Box2D.BL.From = Vector2.new(BX, BY + SizeY) Box2D.BL.To = Vector2.new(BX + Length, BY + SizeY)
                Box2D.BR.From = Vector2.new(BX + SizeX, BY + SizeY) Box2D.BR.To = Vector2.new(BX + SizeX - Length, BY + SizeY)
                
                for _, line in pairs(Box2D) do line.Color = PColor line.Visible = true end
            else
                for _, line in pairs(Box2D) do line.Visible = false end
            end

            -- Vector Snapline Tracers
            if Config.EspTracer then
                local Leg, LegOnScreen = Camera:WorldToViewportPoint(Root.Position - Vector3.new(0, 3, 0))
                if LegOnScreen then
                    Line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    Line.To = Vector2.new(Leg.X, Leg.Y)
                    Line.Color = PColor
                    Line.Visible = true
                else Line.Visible = false end
            else Line.Visible = false end
        else
            -- [DỌN DẸP RÁC] NẾU ĐỐI THỦ CHẾT HOẶC KHÔNG THỎA MÃN ĐIỀU KIỆN RENDER -> TIÊU HỦY NGAY LẬP TỨC
            Line.Visible = false
            for _, line in pairs(Box2D) do line.Visible = false end
            if Char then
                local b = Char:FindFirstChild("WangBox") if b then b.Visible = false end
                local t = Char:FindFirstChild("WangTag") if t then t.Enabled = false end
            end
        end
    end
end)

